  "testing_attributes": {
    "rule": "All interactive and key informational elements MUST include a data-testid attribute.",
    "convention": "kebab-case, role-based",
    "examples": ["data-testid='login-submit-btn'", "data-testid='property-card-book-btn'", "data-testid='filter-location-select'"]
  },
  "instructions_to_main_agent": [
    "Prioritize using pre-existing components from /src/components/ui/ (alert, button, card, dialog, input, etc.). All components are in .jsx.",
    "Create pages as .jsx components. Do not use TypeScript (.tsx).",
    "The application acts as both a high-end marketing site and a data-dense property management dashboard. Apply wide, asymmetrical layouts for the marketing pages and tight bento grids for the dashboard views.",
    "Ensure the hero section overlay is subtle (bg-black/30 or gradient) so the background property image remains clearly visible.",
    "Do NOT use pure #000000. Use Tailwind's slate-900 or the defined primary color #0B132B.",
    "Integrate lucide-react for all iconography.",
    "Do not use generic Bootstrap layouts. Rely heavily on Tailwind CSS for grid-cols and responsive behaviors.",
    "Apply Playfair Display font to all major headings and Manrope to all UI data, labels, and forms. Import these via index.css.",
    "Ensure contrast requirements are met (APCA/WCAG AA). Avoid gray text on gray backgrounds.",
    "Add transition effects to property cards, buttons, and dialogs. Use explicit transform scales and opacity changes instead of 'all'."
  ],
  "universal_guidelines_for_main_agent": [
    "You tend to converge toward generic, 'on distribution' outputs. Avoid this: make creative, distinctive frontends that surprise and delight.",
    "Don't make generic centered layouts, simplistic gradients, and uniform styling.",
    "Create depth through layered design elements with z-index hierarchy and glassmorphism.",
    "You MUST NOT apply universal transition. Eg: transition: all. Always add transitions for specific interactive elements excluding transforms.",
    "You MUST NOT center align the app container, ie do not add .App { text-align: center; }.",
    "NEVER use AI assistant Emoji characters like 🤖🧠💭💡🔮🎯 etc for icons.",
    "Use 2-3x more spacing than feels comfortable. Cramped designs look cheap.",
    "NEVER use placeholder URLs. Always use the provided image URLs.",
    "Use sonner for toast notifications."
  ]
}
