{
  "theme_and_emotion": {
    "archetype": "ARCHETYPE 5: LUXURY (Premium, Depth, Mystery) infused with ORGANIC & EARTHY",
    "emotion": "Architectural Precision mixed with Warm Hospitality",
    "description": "The House Rent Management System should feel like a high-end architectural digest rather than a generic SaaS tool. It bridges the gap between premium real estate marketing and hyper-functional property management dashboards. Tension is created by pairing heavy, classic serif fonts with sterile, modern functional UI components."
  },
  "typography": {
    "font_imports": "@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800&display=swap');",
    "headings": {
      "font_family": "'Playfair Display', serif",
      "strategy": "Expressive, tight tracking (tracking-tight), luxurious scale. Use for Marketing hero, Property Titles, and prominent section headers.",
      "sizes": {
        "h1": "text-4xl sm:text-5xl lg:text-6xl tracking-tighter leading-none",
        "h2": "text-2xl sm:text-3xl lg:text-4xl tracking-tight leading-tight",
        "h3": "text-xl sm:text-2xl tracking-tight"
      }
    },
    "body_and_ui": {
      "font_family": "'Manrope', sans-serif",
      "strategy": "Sterile, highly legible, geometric. Used for dashboards, forms, property metadata, and generic UI copy.",
      "sizes": {
        "body": "text-base leading-relaxed text-slate-700",
        "labels": "text-xs font-semibold uppercase tracking-[0.15em] text-slate-500",
        "ui_small": "text-sm text-slate-600"
      }
    },
    "forbidden_fonts": ["Inter", "Roboto", "Open Sans", "Space Grotesk"]
  },
  "colors": {
    "strategy": "High contrast, rich tones. Never use pure black or pure white. Tint neutrals.",
    "palette": {
      "background": "#FDFBF7",
      "surface": "#FFFFFF",
      "primary": "#0B132B",
      "primary_hover": "#162447",
      "accent_emerald": "#065A4A",
      "accent_emerald_hover": "#044236",
      "text_main": "#0B132B",
      "text_muted": "#475569",
      "border": "#E2E8F0"
    },
    "dashboard_specific": {
      "metric_positive": "#065A4A",
      "metric_negative": "#B91C1C",
      "metric_warning": "#D97706"
    },
    "forbidden_colors": ["#7351B7", "#1B93A4"]
  },
  "spacing_and_layout": {
    "spacing_scale": "Generous. Use 2-3x typical spacing. p-6, p-8, p-12, p-16, p-24.",
    "marketing_layout": "Mode A: Tetris Grid. Asymmetrical grid logic. col-span-full md:col-span-8 row-span-2 for hero elements. Wide gaps (gap-8 to gap-12).",
    "dashboard_layout": "Mode B: High Density Grid. Tight gaps (gap-4 or gap-6). Cards should be flat, no drop-shadows by default, 1px border-slate-200.",
    "alignment": "Optical alignment over geometrical. Left-align dense content. Do not center everything."
  },
  "surface_strategies": {
    "header_nav": "Crystal Glassmorphism. backdrop-blur-xl bg-white/70. 1px delicate inner stroke (border-white/40). Do not use fully transparent headers over hero sections.",
    "hero_overlay": "Max overlay opacity bg-black/40. If contrast is needed, use a gradient bg-gradient-to-t from-black/60 to-transparent. Let the property image breathe.",
    "property_cards": "Flat background, 1px subtle border (border-border), no shadow. On hover: slight lift (-translate-y-1) and shadow-lg.",
    "dashboard_panels": "Sharp edges or max 8px border-radius (rounded-lg). Avoid heavy card looks; use border-collapse styles or subtle separators."
  },
  "component_usage_rules": {
    "base": "Use Shadcn/UI for all interactive logic (Forms, Dialogs, Selects, Dropdowns) customized with Tailwind to match the luxury aesthetic.",
    "forms": "Never use native <input> or <select>. Use Shadcn Input, Select, Checkbox.",
    "charts": "Use Recharts or Shadcn Charts. Minimalist tooltips, remove excessive grid lines.",
    "tables": "Shadcn Table. Flat design, hover states on rows. No alternating row colors, use subtle bottom borders instead.",
    "icons": "Use lucide-react (already installed).",
    "toasts": "Use sonner. Render toaster at the root level.",
    "dropdowns": "No transparent backgrounds. Must have a solid bg-white or bg-slate-900 with clear borders.",
    "files_extension": "All React components must be .jsx. Avoid .tsx extensions."
  },
  "motion_and_interactions": {
    "hover_states": "All buttons/links must have explicit hover colors (e.g., hover:bg-slate-900 hover:text-white). Do not rely on inheritance.",
    "transitions": "Use specific properties (transition-transform duration-300 ease-out). Never use 'transition-all'.",
    "animations": "Subtle fade-in and slide-up for property cards. Staggered entrances for dashboard lists."
  },
