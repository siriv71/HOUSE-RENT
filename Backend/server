@api.get("/bookings")
async def list_bookings(user=Depends(get_current_user), scope: str = "mine"):
    q: dict = {}
    if user["role"] == "admin" and scope == "all":
        pass
    elif scope == "owner":
        prop_ids = []
        async for p in db.properties.find({"owner.id": user["id"]}, {"id": 1}):
            prop_ids.append(p["id"])
        q["property.id"] = {"$in": prop_ids}
    else:
        q["user.id"] = user["id"]
    items = await db.bookings.find(q, {"_id": 0}).sort("created_at", -1).to_list(500)
    return {"items": items}


@api.put("/bookings/{bid}")
async def update_booking(bid: str, data: BookingStatusIn, user=Depends(get_current_user)):
    doc = await db.bookings.find_one({"id": bid})
    if not doc:
        raise HTTPException(404, "Not found")
    prop = await db.properties.find_one({"id": doc["property"]["id"]})
    is_owner = prop and prop["owner"]["id"] == user["id"]
    is_booker = doc["user"]["id"] == user["id"]
    is_admin = user["role"] == "admin"
    if not (is_owner or is_booker or is_admin):
        raise HTTPException(403, "Not allowed")
    updates = {"status": data.status}
    if data.paymentStatus:
        updates["paymentStatus"] = data.paymentStatus
    await db.bookings.update_one({"id": bid}, {"$set": updates})
    return await db.bookings.find_one({"id": bid}, {"_id": 0})


