@api.put("/properties/{pid}")
async def update_property(pid: str, data: PropertyIn, user=Depends(get_current_user)):
    doc = await db.properties.find_one({"id": pid})
    if not doc:
        raise HTTPException(404, "Not found")
    if doc["owner"]["id"] != user["id"] and user["role"] != "admin":
        raise HTTPException(403, "Not allowed")
    updates = data.model_dump()
    if user["role"] != "admin":
        updates["approvalStatus"] = "pending"
    await db.properties.update_one({"id": pid}, {"$set": updates})
    return await db.properties.find_one({"id": pid}, {"_id": 0})


