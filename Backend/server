@api.get("/properties")
async def list_properties(
    location: Optional[str] = None,
    propertyType: Optional[str] = None,
    minPrice: Optional[float] = None,
    maxPrice: Optional[float] = None,
    bedrooms: Optional[int] = None,
    furnishing: Optional[str] = None,
    availability: Optional[bool] = None,
    ownerId: Optional[str] = None,
    approvalStatus: Optional[str] = "approved",
    limit: int = Query(50, le=200),
    skip: int = 0,
):
    q: dict = {}
    if approvalStatus and approvalStatus != "all":
        q["approvalStatus"] = approvalStatus
    if location:
        q["$or"] = [
            {"city": {"$regex": location, "$options": "i"}},
            {"location": {"$regex": location, "$options": "i"}},
            {"state": {"$regex": location, "$options": "i"}},
        ]
    if propertyType and propertyType != "all":
        q["propertyType"] = propertyType
    if bedrooms is not None:
        q["bedrooms"] = {"$gte": bedrooms}
    if furnishing and furnishing != "all":
        q["furnishing"] = furnishing
    if availability is not None:
        q["availability"] = availability
    if ownerId:
        q["owner.id"] = ownerId
    price_q = {}
    if minPrice is not None:
        price_q["$gte"] = minPrice
    if maxPrice is not None:
        price_q["$lte"] = maxPrice
    if price_q:
        q["price"] = price_q

    total = await db.properties.count_documents(q)
    cursor = db.properties.find(q, {"_id": 0}).sort("created_at", -1).skip(skip).limit(limit)
    items = await cursor.to_list(limit)
    return {"items": items, "total": total}


