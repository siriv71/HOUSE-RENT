@api.get("/admin/dashboard")
async def admin_dashboard(_=Depends(require_admin)):
    total_users = await db.users.count_documents({})
    total_properties = await db.properties.count_documents({})
    total_bookings = await db.bookings.count_documents({})
    pending_listings = await db.properties.count_documents({"approvalStatus": "pending"})
    approved_listings = await db.properties.count_documents({"approvalStatus": "approved"})

    months = defaultdict(int)
    booking_months = defaultdict(int)
    revenue_months = defaultdict(float)
    async for p in db.properties.find({}, {"created_at": 1}):
        try:
            months[p["created_at"][:7]] += 1
        except Exception:
            pass
    async for b in db.bookings.find({}, {"created_at": 1, "property": 1, "status": 1}):
        try:
            key = b["created_at"][:7]
            booking_months[key] += 1
            if b.get("status") == "confirmed":
                revenue_months[key] += float(b.get("property", {}).get("price", 0))
        except Exception:
            pass

    def series(d):
        return [{"month": k, "value": v} for k, v in sorted(d.items())]

    return {
        "stats": {
            "totalUsers": total_users, "totalProperties": total_properties,
            "totalBookings": total_bookings, "pendingListings": pending_listings,
            "approvedListings": approved_listings,
        },
        "monthlyListings": series(months),
        "monthlyBookings": series(booking_months),
        "monthlyRevenue": series(revenue_months),
    }


